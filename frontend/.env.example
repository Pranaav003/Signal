# Leave empty for local dev (Vite proxies /api → SIGNAL_API_PROXY, default http://127.0.0.1:3001)
# On Render, VITE_API_URL is injected from the backend service URL at build time.
VITE_API_URL=

# Optional (dev only): where Vite proxies /api. Set if your API is not on port 3001.
# SIGNAL_API_PROXY=http://127.0.0.1:3001
