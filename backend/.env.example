# Set to true to use mockRedditService (no Reddit API keys required)
USE_MOCK_REDDIT=false

PORT=3001
DATABASE_URL=postgresql://YOUR_USER@127.0.0.1:5432/signal_dev
REDIS_URL=redis://localhost:6379
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Signal/1.0 by YourRedditUsername
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
OPENAI_MODEL=
JWT_SECRET=changeme
