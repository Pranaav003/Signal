PORT=3001
DATABASE_URL=postgresql://YOUR_USER@127.0.0.1:5432/signal_dev
REDIS_URL=redis://localhost:6379
# Public Reddit JSON API — OAuth not required. User-Agent is strongly recommended.
REDDIT_USER_AGENT=Signal/1.0 by YourRedditUsername
# Delay between Reddit requests in ms (min 1500; default 2000). Values under 1500 cause 429s.
REDDIT_REQUEST_DELAY_MS=2000
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
OPENAI_MODEL=
JWT_SECRET=changeme
